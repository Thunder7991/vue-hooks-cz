{
  "name": "vue-hooks-cz",
  "version": "0.0.2",
  "description": "Reusable Vue 3 composition hooks.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "core/use*/README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./useDdGeolocation": {
      "types": "./dist/core/useGeolocation/dd.d.ts",
      "import": "./dist/useGeolocation/dd.js",
      "require": "./dist/useGeolocation/dd.cjs"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./dist/core/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "dingtalk-jsapi": "*",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "dingtalk-jsapi": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plugin-dts": "5.0.3",
    "vue": "3.5.39"
  },
  "keywords": [
    "vue",
    "composition-api",
    "hooks",
    "vite"
  ],
  "license": "MIT"
}
